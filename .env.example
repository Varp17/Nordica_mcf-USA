# ─────────────────────────────────────────────────────────────
#  SERVER
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
#  MYSQL DATABASE (Local XAMPP/WAMP defaults)
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=nordica_ecomli
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────
#  REDIS (Optional for local dev, required for prod job queues)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────
#  JWT (Admin auth)
# ─────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────────────────────
#  AMAZON SP-API (US Fulfillment via MCF)
# ─────────────────────────────────────────────────────────────
LWA_CLIENT_ID=amzn1.application-oa2-client.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LWA_CLIENT_SECRET=amzn1.oa2-cs.v1.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LWA_REFRESH_TOKEN=Atzr|XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

AMAZON_SELLER_ID=AXXXXXXXXXX
AMAZON_MARKETPLACE_ID_US=ATVPDKIKX0DER
AMAZON_MARKETPLACE_ID_CA=A2EUQ1WTGCTBG2
SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# AWS IAM credentials for SP-API request signing
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=us-east-1
AMAZON_SANDBOX=false

# ─────────────────────────────────────────────────────────────
#  SHIPPO (Canada Fulfillment)
# ─────────────────────────────────────────────────────────────
SHIPPO_API_TOKEN=shippo_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# SHIPPO_API_KEY=shippo_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Warehouse / From-address
SHIPPO_FROM_NAME=Detail Guardz
SHIPPO_FROM_STREET1=123 Warehouse Street
SHIPPO_FROM_CITY=Toronto
SHIPPO_FROM_STATE=ON
SHIPPO_FROM_ZIP=M5H2N2
SHIPPO_FROM_COUNTRY=CA
SHIPPO_FROM_PHONE=+14165551234
SHIPPO_FROM_EMAIL=shipping@detailguardz.com
SHIPPO_PREFERRED_CARRIER=Canada Post

# ─────────────────────────────────────────────────────────────
#  EMAIL (Nodemailer / SES / SMTP)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=Detail Guardz
EMAIL_FROM_ADDRESS=noreply@detailguardz.com

# ─────────────────────────────────────────────────────────────
#  AWS S3 ASSETS (Production image delivery)
# ─────────────────────────────────────────────────────────────
ASSETS_S3_BASE_URL=https://detailguardz.s3.us-east-1.amazonaws.com
AWS_BUCKET_NAME=detailguardz
# AWS_ACCESS_KEY_ID (Shared with SP-API above)
# AWS_SECRET_ACCESS_KEY (Shared with SP-API above)
# AWS_REGION (Shared with SP-API above)

# ─────────────────────────────────────────────────────────────
#  STORE SETTINGS
# ─────────────────────────────────────────────────────────────
STORE_NAME=Detail Guardz
STORE_SUPPORT_EMAIL=support@detailguardz.com
STORE_WEBSITE=https://detailguardz.com
