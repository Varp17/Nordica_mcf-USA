# ─────────────────────────────────────────────────────────────
#  SERVER
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
#  MYSQL DATABASE
# ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ecommerce_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────────────────────
#  REDIS (for Bull job queues & token cache)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────────────────────
#  JWT (Admin auth)
# ─────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────────────────────
#  AMAZON SP-API  (US Fulfillment via MCF)
# ─────────────────────────────────────────────────────────────
# Login With Amazon (LWA) credentials — from Seller Central > Apps > Develop Apps
LWA_CLIENT_ID=amzn1.application-oa2-client.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LWA_CLIENT_SECRET=amzn1.oa2-cs.v1.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LWA_REFRESH_TOKEN=Atzr|XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Seller / Merchant ID (Account Info page in Seller Central)
AMAZON_SELLER_ID=AXXXXXXXXXX

# Marketplace IDs
AMAZON_MARKETPLACE_ID_US=ATVPDKIKX0DER
AMAZON_MARKETPLACE_ID_CA=A2EUQ1WTGCTBG2

# SP-API endpoint (North America region)
SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# AWS IAM credentials for SigV4 request signing
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=us-east-1

# Set to "true" to use Amazon sandbox for testing
AMAZON_SANDBOX=false

# ─────────────────────────────────────────────────────────────
#  SHIPPO  (Canada Fulfillment)
# ─────────────────────────────────────────────────────────────
# Use shippo_test_xxx for testing, shippo_live_xxx for production
SHIPPO_API_KEY=shippo_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your warehouse / from-address details
SHIPPO_FROM_NAME=Your Store Name
SHIPPO_FROM_STREET1=123 Warehouse Street
SHIPPO_FROM_CITY=Toronto
SHIPPO_FROM_STATE=ON
SHIPPO_FROM_ZIP=M5H2N2
SHIPPO_FROM_COUNTRY=CA
SHIPPO_FROM_PHONE=+14165551234
SHIPPO_FROM_EMAIL=shipping@yourstore.com

# Preferred Canada carrier: "Canada Post" | "UPS" | "FedEx" | "Purolator"
SHIPPO_PREFERRED_CARRIER=Canada Post

# ─────────────────────────────────────────────────────────────
#  EMAIL  (Nodemailer — using SendGrid SMTP)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM_NAME=Your Store Name
EMAIL_FROM_ADDRESS=noreply@yourstore.com

# ─────────────────────────────────────────────────────────────
#  STORE DETAILS
# ─────────────────────────────────────────────────────────────
STORE_NAME=Your Store Name
STORE_SUPPORT_EMAIL=support@yourstore.com
STORE_WEBSITE=https://yourstore.com

# ─────────────────────────────────────────────────────────────
#  AWS S3 ASSETS (For production image delivery)
# ─────────────────────────────────────────────────────────────
# The public base URL for your S3 bucket (e.g., https://bucket-name.s3.region.amazonaws.com)
ASSETS_S3_BASE_URL=
AWS_BUCKET_NAME=
